# Exchange credentials (Binance)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Use testnet for paper trading (recommended first)
USE_TESTNET=true

# spot = long only | futures = long + short
TRADING_MODE=spot

# Trading pair
SYMBOL=BTC/USDT

# Risk management (percentages as decimals, e.g. 0.002 = 0.2%)
MAX_RISK_PER_TRADE=0.002
TAKE_PROFIT_MIN=0.01
TAKE_PROFIT_MAX=0.02
STOP_LOSS_PERCENT=0.002

# Trailing stop: activates once trade is up 0.5%, trails 0.3% behind the peak
TRAILING_ACTIVATION_PERCENT=0.005
TRAILING_STOP_PERCENT=0.003

# Scanning parameters
TIMEFRAME=1m
CANDLE_LIMIT=100
SCAN_INTERVAL_MS=10000

# Position limits
MAX_OPEN_POSITIONS=1
MAX_HOLD_HOURS=6
MIN_SIGNAL_STRENGTH=0.60

# Safety limits
MAX_DAILY_LOSS_PERCENT=0.02
MIN_ORDER_USDT=10

# Dashboard API
API_PORT=3000
